# macOS
.DS_Store
.AppleDouble
.LSOverride

# Claude Code — local-only settings (never share)
.claude/

# Ansible
*.retry
.ansible/
__pycache__/
*.pyc

# Inventory — echte IPs und lokale Node-Infos nie ins öffentliche Repo
infra/inventory/hosts.yml
infra/inventory/local.yml

# Agent-Worklogs — lokale Implementierungsdetails, nicht für öffentliches Repo
# memory.md wird getrackt (Entscheidungshistorie), Worklogs bleiben lokal
.agent/

# Secrets — never commit plaintext
*.age
.env
.env.*
*_secret*
*_token*
*_key*
# secrets.sops.yml (verschlüsselt) wird getrackt — nur Klartext-Zwischenstand schützen
infra/inventory/group_vars/secrets.sops.yml.plaintext

# Encrypted SOPS files (tracked, but excluded from accidental plaintext commits)
# .sops.yaml is intentionally tracked (contains only public age key)

# Editor
*.swp
*.swo
.idea/
.vscode/
