{
  "permissions": {
    "allow": [
      "Bash(ansible-lint:*)",
      "Bash(ansible-playbook*--check*:*)",
      "Bash(ansible-playbook*--diff*:*)",
      "Bash(helm lint:*)",
      "Bash(helm template:*)",
      "Bash(helm list:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(git log:*)",
      "Bash(git blame:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)"
    ],
    "deny": [
      "Bash(kubectl delete:*)",
      "Bash(kubectl apply:*)",
      "Bash(ansible-playbook*--become*:*)",
      "Bash(sops*-i*:*)",
      "Bash(helm uninstall:*)",
      "Bash(helm upgrade:*)"
    ]
  }
}
